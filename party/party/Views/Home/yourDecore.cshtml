@model party.Models.SpecialRequestModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<hr />
<div id="events" class="events-box">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="title-box">
                    <h1 align="center">قبل ان ترسل الطلب قم بالبحث عن المنسقين و اعمالهم لكى تختار  منهم مشرفا على مناسبتك</h1>

                    @using (Html.BeginForm("yourDecore", "Home", FormMethod.Post, new { name = "sg", enctype = "multipart/form-data" }))
                    {


                        <form>
                            @if (TempData["Message"] != null)
                            {
                                <div class="alert alert-danger">
                                    <p style="color:black">@TempData["Message"]</p>
                                </div>
                            }

                            <div class="mb-3">
                                <h3 align="right">المناسبة</h3>
                                <input name="monsba" dir="rtl" type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">متطليات الديكور</h3>
                                <input name="des" dir="rtl" type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">تاريخ المناسبة</h3>
                                <input name="date" dir="rtl" type="date" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">الاسم</h3>
                                <input name="ClientName" dir="rtl" type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">رقم الهاتف للتواصل</h3>
                                <input name="ClientPhone" dir="rtl" type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">عنوان العميل</h3>
                                <input name="ClientAdress" dir="rtl" type="text" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                            </div>
                            <div class="mb-3">
                                <h3 align="right">أختار المنسق</h3>

                                @Html.DropDownListFor(m => m.coordinatorObject.Id, new SelectList(Model.coordinatorsList, "Id", "name", "select"), new { @class = "form-control", dir = "rtl" })
                            </div>
                            <div class="mb-3 form-check">
                                <h3 align="right">الصورة</h3>
                                <input class="form-control" dir="ltr" type="file" name="imgfile" />
                            </div>

                            <button type="submit" class="btn btn-primary">ارسال البيانات</button>


                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
