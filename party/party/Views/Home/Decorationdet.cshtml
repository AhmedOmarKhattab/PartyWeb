@model party.Models.allProject

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br /><br /><br /><br />

<style>
    /* Styles for layout */
    .product-details {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .main-image {
        flex: 1 0 60%;
        border: 1px solid #ddd;
        padding: 10px;
        text-align: center;
    }

        .main-image img {
            max-width: 100%;
            max-height: 400px;
        }

    .thumbnail-images {
        flex: 1 0 30%;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .thumbnail-images img {
            max-width: 100%;
            cursor: pointer;
            border: 1px solid #ddd;
        }
</style>

<hr />
<h1 align="center">@Model.decoration.decoreName</h1>
<div class="product-details">
    <div class="main-image">
        <img class="img-fluid" width="300" src="@Url.Content(Model.decoration.image)" alt="..." />
    </div>
    <div class="thumbnail-images">
        <img class="img-fluid" width="300" src="@Url.Content(Model.decoration.imageTwo)" alt="..." />
        <img class="img-fluid" width="300" src="@Url.Content(Model.decoration.image)" alt="..." />
        <!-- Add more thumbnails as needed -->
    </div>
</div>
<div class="col-lg-12 col-md-6 col-sm-12">
    <div class="event-inner" style="background-color:lightblue">
        <div class="event-img">
            <!-- Place the image here -->
            <img  width="100" src="@Url.Content(Model.decoration.coordinator.image)" alt="..." />
            <!-- End of image -->
            <div class="product-info">
                <br /><br />
                <h2>@Model.decoration.decoreName</h2>
                <strong>السعر :@Model.decoration.cost</strong>
                <h3>@Model.decoration.des</h3>
                <strong>اسم المنسق :@Model.decoration.coordinator.name</strong>
            </div>
            <center>
                <a href="~/Home/BookDecore?decoreId=@Model.decoration.Id" class="btn btn-danger">حجز القاعة</a>

            </center>
        </div>
    </div>
</div>


<br /><br /><br /><br /><br /><br /><br />
