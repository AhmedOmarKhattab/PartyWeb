
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br /><br /><br />
<div id="about" class="about-box" dir="rtl">
    <div class="about-a1">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="title-box">
                        <h2>الخدمات <span>  </span> المقدمة من الموقع </h2>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12">
                    <div class="row align-items-center about-main-info">
                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <div class="about-m">
                                <div class="about-img">
                                    <img class="img-fluid" src="~/Content/images/about-img-01.jpg" alt="" />
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-8 col-md-6 col-sm-12">
                            <h2 align="right"> <i class="fa fa-heart-o" aria-hidden="true"></i> <span>تنسيق المواعيد</span> <i class="fa fa-heart-o" aria-hidden="true"></i></h2>
                            <p align="right">
                                الموقع يستخدم لاختيار منسق للحفلات، حيث يمكن للمستخدم أن يقوم باختيار شخص أو شركة متخصصة في تنظيم الحفلات. بمجرد دخول الموقع، يمكنك الاطلاع على مجموعة من المنسقين للحفلات المتاحين والمتخصصين في هذا المجال.
                            </p>
                        </div>
                    </div>
                    <div class="row align-items-center about-main-info">
                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <div class="about-m">
                                <div class="about-img">
                                    <img class="img-fluid" src="~/Content/images/about-img-02.jpg" alt="" />
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-8 col-md-6 col-sm-12">
                            <h2 align="right"> <i class="fa fa-heart-o" aria-hidden="true"></i> <span>تنسيق الديكور المناسب لك </span> <i class="fa fa-heart-o" aria-hidden="true"></i></h2>
                            <p align="right">
                                يمكن للمستخدم القيام بالاستعلام حول الخدمات المقدمة من قبل هؤلاء المنسقين. يتيح لك الموقع فحص وفهم نطاق الخدمات المتاحة، مثل التخطيط، وتنسيق الديكور، واختيار الأماكن المناسبة، وتوفير الخدمات الأخرى ذات الصلة بتنظيم الحفلات.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>