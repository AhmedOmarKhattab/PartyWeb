<!-- Start Events -->
<div id="events" class="events-box">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="title-box">
                    <h2>عرض بعض المسقين المتعاقدين مع الموقع</h2>
                </div>
            </div>
        </div>
        <div class="row">
            @foreach (var item in Model.coordinators)
            {
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <div class="event-inner">
                        <div class="event-img">
                            <img  height="200" width="300" src="@Url.Content(item.image)" alt="" />
                        </div>

                        <h2>اسم المنسق : @item.name</h2>
                        @*<a href="~/Home/Decorationdet?id=@item.Id">عرض التفاصيل <i class="fa fa-angle-double-right" aria-hidden="true"></i></a>*@
                    </div>
                </div>
            }
        </div>
       
    </div>
</div>

<!-- End Events -->
