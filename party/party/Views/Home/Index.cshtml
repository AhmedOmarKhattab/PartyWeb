@model party.Models.allProject

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- End header -->
<!-- Start Banner -->
<div class="home-slider">
    <ul class="rslides">
        <li><img src="~/Content/images/slider-01.jpg" alt=""></li>
        <li><img src="~/Content/images/slider-02.jpg" alt=""></li>
        <li><img src="~/Content/images/slider-03.jpg" alt=""></li>
    </ul>
    <div class="lbox-details">
        <h1>Karlene Hoard  & Jonas Pare</h1>
        <h2>    كارلن للمناسبات</h2>

    </div>
</div>
<!-- End Banner -->
<!-- Start About us -->
<div id="events" class="events-box">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="title-box">
                    <h2>عرض القاعات </h2>
                </div>
            </div>
        </div>
        <div class="row">
            @foreach (var item in Model.decorations)
            {
                <div class="col-lg-4 col-md-6 col-sm-12">
                    <div class="event-inner">
                        <div class="event-img">
                            <img height="200" width="300" src="@Url.Content(item.image)" alt="" />
                        </div>
                        <h2> @item.decoreName</h2>

                        <h2>اسم المنسق : @item.coordinator.name</h2>
                        <a href="~/Home/Decorationdet?id=@item.Id">عرض التفاصيل <i class="fa fa-angle-double-right" aria-hidden="true"></i></a>
                    </div>
                </div>
            }

        </div>
        <center>
            <a href="~/Home/CoorList" class="btn btn-danger">عرض المزيد <i class="fa fa-angle-double-right" aria-hidden="true"></i></a>

        </center>
    </div>
</div>
<!-- End About us -->
<!-- Start Story -->
<div id="story" class="story-box main-timeline-box">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="title-box">
                    <h2>صور من بعض المناسبات التى قمنا بتسيقها</h2>
                </div>
            </div>
        </div>

        <div class="timeLine">
            <div class="row">
                <div class="lineHeader hidden-sm hidden-xs"></div>
                <div class="lineFooter hidden-sm hidden-xs"></div>

                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 item">
                    <div class="caption">
                        <div class="star center-block">
                            <span class="h3">01</span>
                            <span>March </span>
                            <span>2017</span>
                        </div>
                        <div class="image">
                            <img src="~/Content/images/time-01.jpg" alt="" />
                            <div class="title">
                                <h2>First Meet <i class="fa fa-angle-right" aria-hidden="true"></i></h2>
                            </div>
                        </div>
                        <div class="textContent">
                            <p class="lead">We met at the wedding of our close friends and immediately found a common language, so a year later our first date happened.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 item">
                    <div class="caption">
                        <div class="star center-block">
                            <span class="h3">03</span>
                            <span>April</span>
                            <span>2017</span>
                        </div>
                        <div class="image">
                            <img src="~/Content/images/time-02.jpg" alt="" />
                            <div class="title">
                                <h2>First date <i class="fa fa-angle-right" aria-hidden="true"></i></h2>
                            </div>
                        </div>
                        <div class="textContent">
                            <p class="lead">We met at the wedding of our close friends and immediately found a common language, so a year later our first date happened.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 item">
                    <div class="caption">
                        <div class="star center-block">
                            <span class="h3">03</span>
                            <span>May</span>
                            <span>2017</span>
                        </div>
                        <div class="image">
                            <img src="~/Content/images/time-03.jpg" alt="" />
                            <div class="title">
                                <h2>Proposal <i class="fa fa-angle-right" aria-hidden="true"></i></h2>
                            </div>
                        </div>
                        <div class="textContent">
                            <p class="lead">We met at the wedding of our close friends and immediately found a common language, so a year later our first date happened.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 item">
                    <div class="caption">
                        <div class="star center-block">
                            <span class="h3">04</span>
                            <span>June</span>
                            <span>2017</span>
                        </div>
                        <div class="image">
                            <img src="~/Content/images/time-04.jpg" alt="" />
                            <div class="title">
                                <h2>Engagement <i class="fa fa-angle-right" aria-hidden="true"></i></h2>
                            </div>
                        </div>
                        <div class="textContent">
                            <p class="lead">For 2 years of work as support engineer responsible about installing and maintenance SWIFT packages for banks. I gain a lot from it before i leave country.</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 item">
                    <div class="caption">
                        <div class="star center-block">
                            <span class="h3">04</span>
                            <span>July</span>
                            <span>2017</span>
                        </div>
                        <div class="image">
                            <img src="~/Content/images/time-05.jpg" alt="" />
                            <div class="title">
                                <h2>My Wedding <i class="fa fa-angle-right" aria-hidden="true"></i></h2>
                            </div>
                        </div>
                        <div class="textContent">
                            <p class="lead">Since then i came to Austria as refugee far from my lovers and friends far a way escaping from wars and threats searching a new life that i didn't find until yet.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>



